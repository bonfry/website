---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PdfSlideshow from '../../components/PdfSlideshow.jsx';
import '../../styles/talks-page.css';
import '../../styles/pdf-slideshow.css';

export async function getStaticPaths() {
    const talks = await getCollection('talks');
    return talks.map(talk => ({
        params: { id: talk.id },
        props: { talk },
    }));
}

const { talk } = Astro.props;
const pdfUrl = `/pdf/${talk.data.pdf_link}`;
const formattedDate = talk.data.date.toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});
---

<Layout title={talk.data.title} description={talk.data.desc} ogType="article">
    <div class="talk-viewer">
        <div class="talk-header">
            <a href="/talks" class="back-link">
                <span class="material-symbols-outlined">arrow_back</span>
                All Talks
            </a>
            <div class="talk-meta">
                <h1 class="talk-title">{talk.data.title}</h1>
                <p class="talk-date">{formattedDate}</p>
                <p class="talk-desc">{talk.data.desc}</p>
            </div>
        </div>

        <PdfSlideshow pdfUrl={pdfUrl} client:only="react" />
    </div>
</Layout>



